* text=auto eol=lf

# Go source
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# YAML / CI / configs
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts may stay CRLF if you use them
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf